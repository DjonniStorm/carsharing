{
  "name": "@carsharing/backend",
  "version": "0.0.1",
  "description": "",
  "author": "Ilya",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts",
    "test:repos": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts repositories",
    "test:services": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts services",
    "test:watch": "cross-env DOTENV_CONFIG_PATH=.env.test vitest --config ./vitest.config.ts",
    "test:cov": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts --coverage",
    "test:debug": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts --inspect-brk --no-file-parallelism",
    "test:e2e": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --config ./vitest.config.ts ./test",
    "prisma:generate": "prisma generate",
    "prisma:db:push:test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test prisma db push --accept-data-loss",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:migrate:sql": "prisma migrate diff --from-empty --to-schema=prisma/schema.prisma --script -o prisma/migrations/20260419120000_init/migration.sql",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:create:test": "docker compose exec -T postgres sh -lc \"psql -U carsharing -d postgres -tA -c \\\"SELECT 1 FROM pg_database WHERE datname = 'carsharing_test'\\\" | grep -q 1 || psql -U carsharing -d postgres -c \\\"CREATE DATABASE carsharing_test\\\"\""
  },
  "dependencies": {
    "@carsharing/types": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "dotenv": "^17.4.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4",
    "cross-env": "^10.1.0",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "bcryptjs": "^3.0.2"
  }
}
