// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Auth profile; plain `password` column from spec omitted — store only hash (see db.md notes).
/// `role` — same numeric values as `UserRole` in application code (0 = MANAGER, 1 = DRIVER, 2 = SYSTEM_ADMIN).
model User {
  id              String         @id @default(uuid()) @db.Uuid()
  name            String         @db.Text()
  email           String         @db.Text()
  phone           String         @db.Text()
  passwordHash    String         @map("hash_password") @db.Text()
  role            Int
  isActive        Boolean        @default(false) @map("is_active")
  isDeleted       Boolean        @default(false) @map("is_deleted")
  trips           Trip[]
  notifications   Notification[]
  geoZonesCreated GeoZone[]      @relation("GeoZoneCreatedBy")

  @@unique([email])
  @@unique([phone])
  @@map("user")
}

/// Lookup / session type (no FK in db.md); kept for reference or future links.
model CarSession {
  id   Int    @id @default(autoincrement())
  name String @db.Text()

  @@map("car_session")
}

/// Базовая сущность автомобиля: паспортные данные и текущее операционное состояние.
/// `carStatus` — те же числовые значения, что и `CarStatus` в коде (1 = AVAILABLE, …).
/// `lastKnownLat` / `lastKnownLon` / `lastPositionAt` — где машина стоит на карте между поездками.
/// Заполняются (или обновляются) только при завершении поездки из последней точки `Telemetry` этой поездки.
/// Во время поездки позицию бери из `Telemetry`, а не из `Car`.
model Car {
  id             String  @id @default(uuid()) @db.Uuid()
  brand          String  @db.Text()
  model          String  @db.Text()
  licensePlate   String  @map("license_plate") @db.Text()
  color          String  @db.Text()
  mileage        Float
  fuelLevel      Float   @map("fuel_level")
  isAvailable    Boolean @map("is_available")
  carStatus      Int     @map("car_status_id")
  isDeleted      Boolean @map("is_deleted")
  createdAt      String  @map("created_at") @db.Text()
  updatedAt      String? @map("updated_at") @db.Text()
  lastKnownLat   Float?  @map("last_known_lat")
  lastKnownLon   Float?  @map("last_known_lon")
  lastPositionAt String? @map("last_position_at") @db.Text()
  trips          Trip[]

  @@unique([licensePlate])
  @@map("car")
}

/// Данные сессии по поездке (1:1 с `Trip`). Координаты конца поездки для карты парка — на `Car.lastKnown*`.
/// Старт поездки при необходимости для отчётов — опционально здесь; трек — в `Telemetry`.
model CarSessionInfo {
  id       Int      @id @default(autoincrement())
  tripId   Int      @unique @map("trip_id")
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  startLat Decimal? @map("start_lat") @db.Decimal(9, 6)
  startLon Decimal? @map("start_lon") @db.Decimal(9, 6)

  @@map("car_session_info")
}

/// Стабильная зона (имя, тип, цвет). Геометрия — в `GeoZoneVersion`; активная версия = `currentVersionId`.
model GeoZone {
  id               String           @id @default(uuid()) @db.Uuid()
  name             String           @db.Text()
  type             String           @db.VarChar(50)
  color            String           @db.VarChar(64)
  currentVersionId String?          @unique @map("current_version_id") @db.Uuid()
  createdAt        DateTime         @default(now()) @map("created_at")
  deletedAt        DateTime?        @map("deleted_at")
  createdByUserId  String           @map("created_by_user_id") @db.Uuid()
  createdByUser    User             @relation("GeoZoneCreatedBy", fields: [createdByUserId], references: [id])
  currentVersion   GeoZoneVersion?  @relation("GeoZoneCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions         GeoZoneVersion[] @relation("GeoZoneVersions")
  tariffs          Tariff[]

  @@map("geo_zone")
}

/// История геометрии и правил зоны (`rules` — JSON, напр. тарифные ограничения).
model GeoZoneVersion {
  id             String                                     @id @default(uuid()) @db.Uuid()
  geozoneId      String                                     @map("geozone_id") @db.Uuid()
  geoZone        GeoZone                                    @relation("GeoZoneVersions", fields: [geozoneId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  geometry       Unsupported("geometry(MultiPolygon,4326)")
  rules          Json?                                      @db.JsonB
  createdAt      DateTime                                   @default(now()) @map("created_at")
  disabledAt     DateTime?                                  @map("disabled_at")
  currentForZone GeoZone?                                   @relation("GeoZoneCurrentVersion")

  @@index([geozoneId])
  @@map("geo_zone_version")
}

model Tariff {
  id             String    @id @default(uuid()) @db.Uuid()
  name           String    @db.Text()
  pricePerMinute Decimal   @map("price_per_minute") @db.Decimal(19, 2)
  pricePerKm     Decimal   @map("price_per_km") @db.Decimal(19, 2)
  geoZoneId      String    @map("geo_zone_id") @db.Uuid()
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  geoZone        GeoZone   @relation(fields: [geoZoneId], references: [id])
  trips          Trip[]

  @@map("tariff")
}

model Trip {
  id             Int             @id @default(autoincrement())
  startTime      DateTime        @map("start_time")
  endTime        DateTime?       @map("end_time")
  distance       Float
  duration       Float
  status         String          @db.VarChar(255)
  userId         String          @map("user_id") @db.Uuid()
  carId          String          @map("car_id") @db.Uuid()
  tariffId       String          @map("tariff_id") @db.Uuid()
  user           User            @relation(fields: [userId], references: [id])
  car            Car             @relation(fields: [carId], references: [id])
  tariff         Tariff          @relation(fields: [tariffId], references: [id])
  carSessionInfo CarSessionInfo?
  telemetries    Telemetry[]
  violations     Violation[]

  @@index([userId])
  @@index([carId])
  @@index([tariffId])
  @@map("trip")
}

model Telemetry {
  id           Int      @id @default(autoincrement())
  timestamp    DateTime
  lat          Decimal  @db.Decimal(9, 6)
  lon          Decimal  @db.Decimal(9, 6)
  speed        Decimal  @db.Decimal(5, 2)
  acceleration Float
  fuelLevel    Float    @map("fuel_level")
  tripId       Int      @map("trip_id")
  trip         Trip     @relation(fields: [tripId], references: [id])

  @@index([tripId])
  @@index([timestamp])
  @@map("telemetry")
}

model Violation {
  id            Int                     @id @default(autoincrement())
  type          Int
  description   String                  @db.Text()
  createdAt     DateTime                @default(now()) @map("created_at")
  tripId        Int                     @map("trip_id")
  trip          Trip                    @relation(fields: [tripId], references: [id])
  notifications ViolationNotification[]

  @@index([tripId])
  @@map("violation")
}

model Notification {
  id         Int                     @id @default(autoincrement())
  message    String                  @db.Text()
  status     String                  @db.VarChar(50)
  userId     String                  @map("user_id") @db.Uuid()
  user       User                    @relation(fields: [userId], references: [id])
  violations ViolationNotification[]

  @@index([userId])
  @@map("notification")
}

model ViolationNotification {
  violationId    Int          @map("violation_id")
  notificationId Int          @map("notification_id")
  violation      Violation    @relation(fields: [violationId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@id([violationId, notificationId])
  @@map("violation_notification")
}
