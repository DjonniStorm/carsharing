# Скопируйте в `.env` и настройте под локальное окружение.
# Строка подключения Prisma/Nest к PostgreSQL.
DATABASE_URL="postgresql://carsharing:carsharing@localhost:5432/carsharing?schema=public"

# Секрет для подписи access и refresh токенов.
# Должен быть уникальным для окружения и не должен попадать в git с реальными значениями.
AUTH_TOKEN_SECRET="change-me-for-local-dev"
